// Prisma schema for the ecommerce backend
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Worker {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  
  // Stripe Connect Account ID (e.g., acct_xxxx)
  stripeConnectId   String?   @unique

  // Stripe Customer ID (cus_xxxx) — used for the platform subscription the worker pays
  stripeCustomerId  String?   @unique

  // --- YE FIELD ADD KAREIN ---
  // Tracks if the worker completed the Stripe Express onboarding flow
  isOnboardingDone  Boolean   @default(false)

  // Worker ke products ka relation
  products          Product[]

  // The worker's platform subscription (e.g. "Pro Seller" plan)
  subscription      Subscription?
}

model Subscription {
  id                   String             @id @default(uuid())
  workerId             String             @unique
  worker               Worker             @relation(fields: [workerId], references: [id], onDelete: Cascade)

  // Stripe references
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  stripePriceId        String?

  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  // Price stored in the smallest currency unit (e.g. cents)
  price       Int
  currency    String      @default("usd")
  stock       Int         @default(0)
  imageUrl    String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Stripe Connect ke liye Product ko Worker se link kiya
  workerId    String?
  worker      Worker?     @relation(fields: [workerId], references: [id])

  orderItems  OrderItem[]
}

model Order {
  id                  String      @id @default(cuid())
  // Total amount in the smallest currency unit (e.g. cents)
  totalAmount         Int
  currency            String      @default("usd")
  status              OrderStatus @default(PENDING)
  customerEmail       String?
  // Stripe references
  stripeSessionId     String?     @unique
  stripePaymentIntent String?     @unique
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  items               OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  // Unit price captured at time of purchase (smallest currency unit)
  unitPrice  Int

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  FULFILLED
}