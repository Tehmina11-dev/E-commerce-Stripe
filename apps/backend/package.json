    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^15.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.41",
